import os
import sys
import argparse
import socket
import requests
import json


def try_url(url, api_key, transport, distance):
    print('\n--- Tester :', url)
    host = url.split('://', 1)[1].split('/', 1)[0]
    try:
        addrs = socket.getaddrinfo(host, None)
        ips = sorted({a[4][0] for a in addrs})
        print('DNS résolu ->', ips)
    except Exception as e:
        print('Échec résolution DNS:', e)

    try:
        r = requests.get(f"{url.rstrip('/')}/transport",
                         headers={"Authorization": f"Bearer {api_key}"},
                         params={"transport": transport, "distance": distance},
                         timeout=10)
        print('HTTP statut:', r.status_code)
        try:
            print(json.dumps(r.json(), indent=2, ensure_ascii=False))
        except Exception:
            print('Corps (début):', r.text[:1000])
        return True
    except Exception as e:
        print('Erreur requête:', type(e).__name__, str(e))
        return False


def main():
    p = argparse.ArgumentParser(description='Simple diagnostic ImpactCO2 transport')
    p.add_argument('--api-key', help='Clé API (ou définir IMPACTCO2_API_KEY)')
    p.add_argument('--transport', default='train')
    p.add_argument('--distance', type=float, default=660)
    p.add_argument('--base-url', default='https://api.impactco2.fr/v1', help='URL initiale à tester')
    args = p.parse_args()

    DEFAULT_API_KEY = 'bb5235c4-bf98-4c94-adf1-e2ea4add2cc2'
    api_key = args.api_key or os.getenv('IMPACTCO2_API_KEY') or DEFAULT_API_KEY
    if api_key == DEFAULT_API_KEY:
        print('Attention: utilisation d\'une clé intégrée (moins sécurisé)')

    candidates = []
    # commencer par la base fournie puis essayer d'autres variantes communes
    candidates.append(args.base_url.rstrip('/'))
    candidates += [
        'https://api.impactco2.fr/v1',
        'https://impactco2.fr/v1',
        'https://impactco2.fr/api',
        'https://impactco2.fr'
    ]

    for url in candidates:
        ok = try_url(url, api_key, args.transport, args.distance)
        if ok:
            print('\nRequête réussie pour', url)
            return

    print('\nAucune des URLs de test n\'a répondu correctement.')
    print('Si ça échoue encore :')
    print('- Vérifiez votre connexion Internet et votre DNS (essayez `nslookup api.impactco2.fr`).')
    print('- Si vous êtes derrière un proxy/pare-feu, configurez `HTTP_PROXY`/`HTTPS_PROXY` ou autorisez la sortie.')
    print('- Essayez d\'accéder à https://impactco2.fr/doc/api dans un navigateur pour voir la doc.')
    print('- Si vous obtenez HTML (page web), essayez les variantes `/v1` ou `/api` comme base-url.')


if __name__ == '__main__':
    main()
